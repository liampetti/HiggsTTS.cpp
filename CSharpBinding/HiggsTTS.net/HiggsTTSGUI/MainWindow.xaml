<Window x:Class="HiggsTTSGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Higgs TTS" Height="680" Width="760"
        Background="#1e1e1e" Foreground="#ddd"
        WindowStartupLocation="CenterScreen"
        SourceInitialized="Window_SourceInitialized">
    <Window.Resources>
        <!-- Dark theme styles -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#ddd"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="CaretBrush" Value="#ddd"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2a2a2a"/>
            <Setter Property="Foreground" Value="#ddd"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3a3a3a"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#ddd"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1e1e1e"/>
            <Setter Property="Foreground" Value="#a08030"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0" Margin="6,4,0,4"
                                                                  VerticalAlignment="Center"
                                                                  TextElement.Foreground="#a08030"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                                <Path Grid.Column="1" x:Name="Arrow"
                                                      Data="M0,0 L4,4 L8,0"
                                                      Stroke="#9090a8" StrokeThickness="1.5"
                                                      Fill="Transparent"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#333333"/>
                                                <Setter Property="BorderBrush" Value="#555"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="true" Focusable="false"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="true"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="#000000"
                                            BorderBrush="#444"
                                            BorderThickness="1" CornerRadius="3"/>
                                    <ScrollViewer Margin="4,4" SnapsToDevicePixels="true">
                                        <StackPanel IsItemsHost="true"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBoxItem: match closed-state + dropdown -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#a08030"/>
            <Setter Property="Background" Value="#1e1e1e"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="Transparent" BorderThickness="1"
                                Padding="6,4">
                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333333"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark scrollbars -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#1e1e1e"/>
        </Style>
        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="#1e1e1e"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#ddd"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Config -->
            <RowDefinition Height="Auto"/>   <!-- Load status -->
            <RowDefinition Height="*"/>      <!-- Text input -->
            <RowDefinition Height="Auto"/>   <!-- Controls -->
            <RowDefinition Height="Auto"/>   <!-- Info -->
        </Grid.RowDefinitions>

        <!-- ═══ Config ═══ -->
        <GroupBox Grid.Row="0" Header="Model Config" Foreground="#aaa" BorderBrush="#333"
                  FontSize="12" Padding="6" Margin="0,0,0,8">
            <GroupBox.HeaderTemplate>
                <DataTemplate>
                    <TextBlock Text="Model Config" Foreground="#aaa" FontSize="12" Margin="4,0"/>
                </DataTemplate>
            </GroupBox.HeaderTemplate>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Model -->
                <Label Grid.Row="0" Grid.Column="0" Content="Model GGUF" VerticalAlignment="Center" Width="90"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtModel" Margin="0,2" VerticalAlignment="Center"/>
                <Button Grid.Row="0" Grid.Column="2" Content="Browse" Click="BrowseModel" Margin="6,2,0,2"
                        Width="60" Padding="6,4"/>
                <Button Grid.Row="0" Grid.Column="3" x:Name="BtnLoad" Content="Load" Click="LoadModel_Click"
                        Margin="6,2,0,2" Width="50" Padding="6,4"
                        Background="#2d5a2d" Foreground="white" FontWeight="Bold"/>
                <Button Grid.Row="0" Grid.Column="4" x:Name="BtnUnload" Content="Unload" Click="UnloadModel_Click"
                        Margin="6,2,0,2" Width="55" Padding="6,4" IsEnabled="False"
                        Background="#5a2d2d" Foreground="white"/>

                <!-- Ref Audio -->
                <Label Grid.Row="1" Grid.Column="0" Content="Ref Audio" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtRefWav" Margin="0,2" VerticalAlignment="Center"/>
                <Button Grid.Row="1" Grid.Column="2" Content="Browse" Click="BrowseRefWav" Margin="6,2,0,2"
                        Width="60" Padding="6,4"/>

                <!-- Tokenizer -->
                <Label Grid.Row="2" Grid.Column="0" Content="Tokenizer" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtTokenizer" Margin="0,2" VerticalAlignment="Center"/>
                <Button Grid.Row="2" Grid.Column="2" Content="Browse" Click="BrowseTokenizer" Margin="6,2,0,2"
                        Width="60" Padding="6,4"/>

                <!-- Ref Text -->
                <Label Grid.Row="3" Grid.Column="0" Content="Ref Text" VerticalAlignment="Center"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtRefText" Margin="0,2" VerticalAlignment="Center"/>
            </Grid>
        </GroupBox>

        <!-- ═══ Load Status ═══ -->
        <TextBlock Grid.Row="1" x:Name="LblStatus" Text="Enter config paths and load model"
                   Foreground="#888" Margin="0,0,0,6" FontSize="12"/>

        <!-- ═══ Text Input ═══ -->
        <Grid Grid.Row="2" Margin="0,0,0,6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label Grid.Row="0" Content="Input Text" Margin="0,0,0,4"/>
            <TextBox Grid.Row="1" x:Name="TxtInput" AcceptsReturn="True" TextWrapping="Wrap"
                     Background="#2a2a28" Foreground="#c8b878"
                     Padding="14" FontSize="15" VerticalScrollBarVisibility="Auto"
                     BorderThickness="1" BorderBrush="#333"
                     Text="Enter text to synthesize here..."
                     GotFocus="TxtInput_GotFocus" LostFocus="TxtInput_LostFocus"/>
        </Grid>

        <!-- ═══ Controls ═══ -->
        <StackPanel Grid.Row="3" Margin="0,4,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Synthesize -->
                <Button Grid.Column="0" x:Name="BtnSynth" Content="Synthesize"
                        Click="Synthesize_Click" IsEnabled="False"
                        Background="#2d5a2d" Foreground="white" FontWeight="Bold"
                        FontSize="14" Padding="18,8" BorderThickness="0"/>

                <!-- Temperature -->
                <Label Grid.Column="1" Content="Temp" Margin="16,0,0,0" VerticalAlignment="Center"/>
                <TextBox Grid.Column="2" x:Name="TxtTemp" Text="0.9" Width="50"
                         TextAlignment="Center" Margin="6,0,0,0" VerticalAlignment="Center"/>

                <!-- Tag -->
                <Label Grid.Column="3" Content="Tag" Margin="16,0,0,0" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="4" x:Name="CmbTag" Width="180" Margin="6,0,0,0" VerticalAlignment="Center"/>

                <!-- Seed -->
                <Label Grid.Column="5" Content="Seed" HorizontalAlignment="Right" Margin="0,0,6,0" VerticalAlignment="Center"/>
                <TextBox Grid.Column="6" x:Name="TxtSeed" Text="42" Width="60"
                         TextAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

            <!-- Playback bar -->
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnPlay" Grid.Column="0" Content="▶" Click="PlayPause_Click"
                        IsEnabled="False" Width="36" Height="36" Padding="0"
                        FontSize="14" FontWeight="Bold"/>

                <Button x:Name="BtnStop" Grid.Column="1" Content="■" Click="Stop_Click"
                        IsEnabled="False" Width="36" Height="36" Padding="0"
                        Margin="6,0,0,0" FontSize="14"/>

                <TextBlock x:Name="LblTime" Grid.Column="2" Text="0:00 / 0:00"
                           Margin="12,0" VerticalAlignment="Center" FontSize="12"
                           MinWidth="80"/>

                <Slider x:Name="SldPosition" Grid.Column="3" Minimum="0" Maximum="1" Value="0"
                        IsEnabled="False" VerticalAlignment="Center"
                        PreviewMouseDown="SldPosition_PreviewMouseDown"
                        PreviewMouseUp="SldPosition_PreviewMouseUp"
                        ValueChanged="SldPosition_ValueChanged"
                        Margin="4,0"/>

                <Button x:Name="BtnSave" Grid.Column="4" Content="Save WAV" Click="Save_Click"
                        IsEnabled="False" Width="80" Margin="12,0,0,0" Padding="10,5"/>
            </Grid>

            <Label x:Name="LblInfo" Content="" Margin="0,4,0,0" VerticalAlignment="Center"
                   FontSize="12"/>
        </StackPanel>

    </Grid>
</Window>
